# Database (shared Postgres on the nyxcore server — dedicated `eventschau` DB)
DATABASE_URL=postgresql://eventschau_app:password@postgres:5432/eventschau
DATABASE_URL_UNPOOLED=postgresql://eventschau_app:password@postgres:5432/eventschau

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=https://e-ventschau.nyxcore.cloud

# Tenant (overrides subdomain resolution — slug differs from subdomain)
TENANT_SLUG=e-ventschau

# Public Site URL (for SEO, sitemap, metadata)
NEXT_PUBLIC_SITE_URL=https://e-ventschau.de
NEXT_PUBLIC_ROOT_DOMAIN=e-ventschau.nyxcore.cloud

# Cloudinary (media uploads — unchanged, media stays on Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI (AI content features)
OPENAI_API_KEY=

# MiniRAG Widget (optional)
NEXT_PUBLIC_MINIRAG_ID=
NEXT_PUBLIC_MINIRAG_URL=
