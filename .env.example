# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Tenant
TENANT_SLUG=e-ventschau

# Public Site URL (for SEO, sitemap, metadata)
NEXT_PUBLIC_SITE_URL=https://e-ventschau.de
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenAI (AI content features)
OPENAI_API_KEY=

# MiniRAG Widget (optional)
NEXT_PUBLIC_MINIRAG_ID=
NEXT_PUBLIC_MINIRAG_URL=
